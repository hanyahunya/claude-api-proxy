# 이 프록시 설정 (전부 선택)
HOST=127.0.0.1
# 기본 8799. 막혀 있으면 자동으로 위 포트를 찾아 띄우고 실제 주소를 출력함
PORT=8799
# 클라이언트 인증 키 검증을 켜려면 설정 (미설정 시 아무 키나 허용)
# PROXY_API_KEY=sk-proxy-anything
# claude 실행파일 경로 (PATH 에 있으면 불필요)
# CLAUDE_BIN=claude
# CLI 한 호출 타임아웃(초)
CLI_TIMEOUT_SEC=600
# claude -p 실행 작업 디렉터리(미설정 시 중립 임시폴더). 프로젝트 CLAUDE.md/스킬 로드 회피용
# PROXY_CLI_CWD=
LOG_LEVEL=INFO
